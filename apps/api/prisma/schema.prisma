generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum Stage {
  PLANTED
  GROWING
  READY
  HARVESTED
}

enum Status {
  ACTIVE
  AT_RISK
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields  Field[]       @relation("AgentFields")
  updates FieldUpdate[]
}

model Field {
  id          String   @id @default(cuid())
  name        String
  cropType    String
  plantingDate DateTime
  expectedHarvestDate DateTime
  stage       Stage    @default(PLANTED)
  status      Status   @default(ACTIVE)
  agentId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent   User?         @relation("AgentFields", fields: [agentId], references: [id])
  updates FieldUpdate[]
}

model FieldUpdate {
  id        String   @id @default(cuid())
  fieldId   String
  agentId   String
  stage     Stage
  notes     String?
  createdAt DateTime @default(now())

  field Field @relation(fields: [fieldId], references: [id])
  agent User  @relation(fields: [agentId], references: [id])
}